<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Comparador de Precios con Cámara</title>
  <style>
    body { font-family: Arial, sans-serif; text-align: center; }
    input { padding: 10px; font-size: 16px; margin: 10px; width: 250px; }
    button { padding: 10px 20px; font-size: 16px; background: #3498db; color: white; border: none; border-radius: 5px; margin: 5px; cursor: pointer; }
    button:hover { background: #2980b9; }
    table { margin: 20px auto; border-collapse: collapse; width: 90%; background: #fff; }
    th, td { border: 1px solid #ddd; padding: 10px; text-align: center; }
    th { background-color: #3498db; color: white; }
    #carrito { font-size: 20px; font-weight: bold; margin: 15px; color: #2c3e50; }
    .oculto { display: none; }
    
    /* Diseño del contenedor de la cámara */
    #lector-camara {
      width: 400px;
      max-width: 90%;
      margin: 20px auto;
      border: 3px solid #3498db;
      border-radius: 8px;
      overflow: hidden;
    }

    /* Caja para la captura manual */
    .manual-box {
      margin: 15px auto;
      padding: 10px;
      width: 380px;
      max-width: 85%;
      border: 1px dashed #7f8c8d;
      border-radius: 5px;
      background: #f8f9fa;
    }
  </style>
  
  <!-- Biblioteca externa para leer códigos de barras con la cámara -->
  <script src="https://unpkg.com" type="text/javascript"></script>
</head>
<body>
  <h2>Comparador de Precios</h2>
  
  <div id="carrito">🛒 Total carrito: $0.00</div>
  
  <button onclick="toggleLista()">👁️ Mostrar / Ocultar lista de compras</button>
  
  <div id="contenedorLista" class="oculto">
    <table id="detalleCarrito">
      <thead>
        <tr>
          <th>Producto</th>
          <th>Cantidad</th>
          <th>Precio unitario</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>
 
  <h3>Escanea el código de barras</h3>
  <div id="lector-camara"></div>
  
  <!-- CUADRO DE TEXTO MANUAL (Alternativa híbrida) -->
  <div class="manual-box">
    <p style="margin: 5px; font-size: 14px; color: #555;">Si la cámara falla, ingresa el código aquí:</p>
    <input type="text" id="codigoManual" placeholder="Escribe el código a mano">
    <button onclick="buscarManual()">Buscar manual</button>
  </div>

  <div id="resultado"></div>
 
  <h3>Respaldo de la base</h3>
  <button onclick="exportarCSV()">Exportar base a CSV</button><br>
  <input type="file" id="archivoCSV" accept=".csv">
  <button onclick="importarCSV()">Importar base desde CSV</button>
 
  <button onclick="resetCarrito()">🔄 Restablecer carrito</button>
 
  <script>
    let productos = JSON.parse(localStorage.getItem("productos")) || {
      "7501234567890": { nombre: "Coca-Cola", presentacion: "500 ml", precioAnterior: 18.00 },
      "7509876543210": { nombre: "Cerveza", presentacion: "1.2 L", precioAnterior: 35.00 }
    };
 
    let totalCarrito = 0;
    let detalle = [];
    let escaneando = true; // Controla que no se repitan lecturas de cámara continuas
 
    function guardarLocal() {
      localStorage.setItem("productos", JSON.stringify(productos));
    }

    function toggleLista() {
      let lista = document.getElementById("contenedorLista");
      lista.classList.toggle("oculto");
    }
 
    function actualizarCarrito() {
      document.getElementById("carrito").textContent = `🛒 Total carrito: $${totalCarrito.toFixed(2)}`;
      let tbody = document.querySelector("#detalleCarrito tbody");
      tbody.innerHTML = "";
      detalle.forEach(item => {
        tbody.innerHTML += `
          <tr>
            <td>${item.nombre}</td>
            <td>${item.cantidad}</td>
            <td>$${item.precio.toFixed(2)}</td>
            <td>$${item.subtotal.toFixed(2)}</td>
          </tr>
        `;
      });
    }
 
    // Captura el código del botón manual
    function buscarManual() {
      let codigo = document.getElementById("codigoManual").value.trim();
      if (!codigo) {
        alert("Por favor ingresa un código de barras.");
        return;
      }
      procesarCodigo(codigo);
      document.getElementById("codigoManual").value = ""; // Limpia la caja de texto
    }

    // Procesa el código (venga de la cámara o de la caja de texto)
    function procesarCodigo(codigo) {
      if (!escaneando) return; 
      escaneando = false; // Pausa el escáner mientras el usuario interactúa
      
      let contenedor = document.getElementById("resultado");
 
      if (productos[codigo]) {
        let p = productos[codigo];
        contenedor.innerHTML = `
          <div style="background: #fdfefe; padding: 15px; border: 1px solid #ddd; margin: 10px auto; width: 60%; border-radius: 5px;">
            <h3>${p.nombre} - ${p.presentacion}</h3>
            <p>Precio anterior: $${p.precioAnterior.toFixed(2)}</p>
            <input type="number" id="precioActual" placeholder="Ingresa precio actual" step="0.01">
            <button onclick="comparar('${codigo}')">Comparar</button>
            <button style="background:#e74c3c" onclick="reanudarEscaneo()">Omitir</button>
          </div>
        `;
      } else {
        contenedor.innerHTML = `
          <div style="background: #fdfefe; padding: 15px; border: 1px solid #ddd; margin: 10px auto; width: 60%; border-radius: 5px;">
            <h3>Producto no registrado (${codigo})</h3>
            <p>Ingresa los datos para guardarlo en la base de datos:</p>
            <input type="text" id="nombre" placeholder="Nombre"><br>
            <input type="text" id="presentacion" placeholder="Presentación"><br>
            <input type="number" id="precioNuevo" placeholder="Precio actual" step="0.01"><br>
            <button onclick="guardarNuevoProducto('${codigo}')">Guardar en la base de datos</button>
            <button style="background:#e74c3c" onclick="reanudarEscaneo()">Cancelar</button>
          </div>
        `;
      }
    }
    
    function reanudarEscaneo() {
      document.getElementById("resultado").innerHTML = "";
      escaneando = true; // Permite a la cámara leer de nuevo
    }
 
    function comparar(codigo) {
      let inputPrecio = document.getElementById("precioActual").value;
      let precioActual = parseFloat(inputPrecio);
      
      if (!inputPrecio || isNaN(precioActual) || precioActual < 0) {
        alert("Por favor ingresa un precio actual válido.");
        return;
      }
 
      let p = productos[codigo];
      let diferencia = precioActual - p.precioAnterior;
      let porcentaje = ((diferencia / p.precioAnterior) * 100).toFixed(2);
 
      document.getElementById("resultado").innerHTML = `
        <div style="background: #fdfefe; padding: 15px; border: 1px solid #ddd; margin: 10px auto; width: 60%; border-radius: 5px;">
          <h3>${p.nombre} - ${p.presentacion}</h3>
          <table>
            <tr>
              <th>Precio anterior</th>
              <th>Precio actual</th>
              <th>Diferencia</th>
            </tr>
            <tr>
              <td>$${p.precioAnterior.toFixed(2)}</td>
              <td>$${precioActual.toFixed(2)}</td>
              <td>$${diferencia.toFixed(2)} (${porcentaje}%)</td>
            </tr>
          </table>
          <button onclick="agregarCarrito('${codigo}', '${p.nombre}', ${precioActual})">➕ Agregar al carrito</button>
          <button style="background:#2ecc71" onclick="reanudarEscaneo()">Terminar / Siguiente</button>
        </div>
      `;
 
      productos[codigo].precioAnterior = precioActual;
      guardarLocal();
    }
 
    function agregarCarrito(codigo, nombre, precioActual) {
      let cantidad = prompt("¿Cuántos artículos deseas agregar?");
      cantidad = parseInt(cantidad);
      if (isNaN(cantidad) || cantidad <= 0) {
        alert("Cantidad inválida.");
        return;
      }
      let subtotal = precioActual * cantidad;
      totalCarrito += subtotal;
      detalle.push({ nombre, cantidad, precio: precioActual, subtotal });
      actualizarCarrito();
    }
 
    function guardarNuevoProducto(codigo) {
      let nombre = document.getElementById("nombre").value.trim();
      let presentacion = document.getElementById("presentacion").value.trim();
      let precioActual = parseFloat(document.getElementById("precioNuevo").value);
 
      if (!nombre || !presentacion || isNaN(precioActual) || precioActual < 0) {
        alert("Por favor ingresa todos los datos correctamente.");
        return;
      }
 
      productos[codigo] = { nombre, presentacion, precioAnterior: precioActual };
      guardarLocal();
 
      document.getElementById("resultado").innerHTML = `
        <div style="background: #e8f4f8; padding: 15px; border-radius: 5px; margin: 10px auto; width: 60%;">
          <p style="color: #27ae60; font-weight: bold;">✔ Producto guardado con éxito en la base de datos.</p>
          <h3>${nombre} - ${presentacion}</h3>
          <p>Precio registrado: $${precioActual.toFixed(2)}</p>
          <button onclick="agregarCarrito('${codigo}', '${nombre}', ${precioActual})">➕ Agregar al carrito</button>
          <button style="background:#2ecc71" onclick="reanudarEscaneo()">Terminar / Siguiente</button>
        </div>
      `;
    }
 
    function exportarCSV() {
      if (Object.keys(productos).length === 0) {
        alert("No hay productos para exportar.");
        return;
      }
 
      let csv = "Codigo,Nombre,Presentacion,PrecioAnterior\n";
      for (let codigo in productos) {
        let p = productos[codigo];
        let nombreSeguro = p.nombre.replace(/,/g, " ");
        let presentacionSegura = p.presentacion.replace(/,/g, " ");
        csv += `${codigo},${nombreSeguro},${presentacionSegura},${p.precioAnterior}\n`;
      }
 
      let blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      let link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = "productos.csv";
      link.click();
    }
 
    function importarCSV() {
      let archivo = document.getElementById("archivoCSV").files;
      if (!archivo) {
        alert("Selecciona un archivo CSV primero.");
        return;
      }
 
      let lector = new FileReader();
      lector.onload = function(e) {
        let lineas = e.target.result.split("\n");
        let importados = 0;
        
        for (let i = 1; i < lineas.length; i++) {
          let linea = lineas[i].trim();
          if (!linea) continue;
          
          let campos = linea.split(",");
          if (campos.length >= 4) {
            let codigo = campos.trim();
            let nombre = campos.trim();
            let presentacion = campos.trim();
            let precioAnterior = parseFloat(campos);
            
            if (codigo && !isNaN(precioAnterior)) {
              productos[codigo] = { nombre, presentacion, precioAnterior };
              importados++;
            }
          }
        }
        guardarLocal();
        alert(`Base importada correctamente. Se actualizaron ${importados} productos.`);
      };
      lector.readAsText(archivo);
    }
 
    function resetCarrito() {
      totalCarrito = 0;
      detalle = [];
      actualizarCarrito();
    }

    // INICIALIZADOR DEL ESCÁNER AL CARGAR LA WEB
    document.addEventListener("DOMContentLoaded", () => {
      const html5QrCode = new Html5Qrcode("lector-camara");
      
      const config = { 
        fps: 15,
        qrbox: { width: 320, height: 160 } 
      };

      html5QrCode.start(
        { facingMode: "environment" },
        config,
        (decodedText) => {
          // Envía el código leído por cámara al procesador
          procesarCodigo(decodedText);
        },
        (errorMessage) => {
          // Silencia los reportes repetitivos de búsqueda
        }
      ).catch((err) => {
        console.error("No se pudo iniciar la cámara:", err);
      });
    });
  </script>
</body>
</html>
